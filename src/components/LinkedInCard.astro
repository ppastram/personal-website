---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  pubDate: Date;
  sourceUrl: string;
  body: string;
  locale: Locale;
}

const { title, pubDate, sourceUrl, body, locale } = Astro.props;
const t = useTranslations(locale);

const readableDate = pubDate.toLocaleDateString(locale === 'es' ? 'es-CO' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const truncated = body.length > 200 ? body.slice(0, 200).trimEnd() + '...' : body;
---

<article class="group">
  <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="block">
    <time datetime={pubDate.toISOString()} class="text-sm font-mono text-muted">
      {readableDate}
    </time>
    <h3 class="text-lg font-heading font-semibold text-heading group-hover:text-accent transition-colors mt-1">
      {title}
    </h3>
    <p class="text-sm text-muted mt-1 line-clamp-3">{truncated}</p>
    <span class="inline-block mt-2 text-sm text-accent group-hover:text-accent-hover transition-colors">
      {t('home.viewOnLinkedIn')} &rarr;
    </span>
  </a>
</article>
