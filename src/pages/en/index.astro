---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayCard from '../../components/EssayCard.astro';
import { useTranslations } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const locale = 'en' as const;
const t = useTranslations(locale);

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home" lang={locale}>
  <section class="mb-16">
    <h1 class="mb-4">Pablo Pastrana Vega</h1>
    <p class="text-lg text-body leading-relaxed max-w-2xl">
      {t('home.hero')}
    </p>
  </section>

  {essays.length > 0 && (
    <section class="mb-16">
      <h2 class="text-sm font-mono text-muted uppercase tracking-wide mb-6">
        {t('home.recentEssays')}
      </h2>
      <div class="grid gap-8">
        {essays.map((essay) => (
          <EssayCard
            title={essay.data.title}
            description={essay.data.description}
            pubDate={essay.data.pubDate}
            tags={essay.data.tags}
            lang={essay.data.lang}
            slug={essay.id}
            locale={locale}
          />
        ))}
      </div>
      <a
        href={`/${locale}/essays/`}
        class="inline-block mt-6 text-sm text-accent hover:text-accent-hover transition-colors"
      >
        {t('home.viewAll')} →
      </a>
    </section>
  )}

  <section>
    <div class="divider mb-8" aria-hidden="true"></div>
    <p class="text-sm text-muted">
      {t('home.currently')} <a href={`/${locale}/building/`} class="text-accent hover:text-accent-hover transition-colors">Dapper</a>.
    </p>
  </section>
</BaseLayout>
