---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readingList, categories, categoryLabels } from '../../data/reading';

const locale = 'en' as const;
---

<BaseLayout title="Reading" lang={locale} description="Books, essays, and thinkers that have shaped how Pablo thinks about product, institutions, and technology.">
  <article class="prose">
    <h1>Reading</h1>
    <p class="text-muted">
      Books and essays that genuinely shifted how I think. Not a "top 10" list — just the ones that stuck.
    </p>

    {categories.map((cat) => {
      const entries = readingList.filter((e) => e.category === cat);
      if (entries.length === 0) return null;
      return (
        <>
          <h2>{categoryLabels[cat].en}</h2>
          <ul>
            {entries.map((entry) => (
              <li>
                <strong>
                  {entry.url ? (
                    <a href={entry.url} target="_blank" rel="noopener noreferrer">{entry.title}</a>
                  ) : (
                    entry.title
                  )}
                </strong>
                {' '}<span class="text-muted">— {entry.author}{entry.year ? ` (${entry.year})` : ''}</span>
                {entry.note && (
                  <br /><span class="text-sm text-muted">{entry.note}</span>
                )}
              </li>
            ))}
          </ul>
        </>
      );
    })}
  </article>
</BaseLayout>
