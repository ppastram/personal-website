    <li>
      <span class="text-sm font-mono text-muted block mb-1">Email</span>
      <a href="mailto:ppastram@gmail.com" class="text-accent hover:text-accent-hover transition-colors">
        ppastram@gmail.com
      </a>
    </li>
    <li>
      <span class="text-sm font-mono text-muted block mb-1">LinkedIn</span>
      <a href="https://linkedin.com/in/pablo-pastrana-vega" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover transition-colors">
        linkedin.com/in/pablo-pastrana-vega
      </a>
    </li>
    <li>
      <span class="text-sm font-mono text-muted block mb-1">WhatsApp</span>
      <a href="https://wa.me/573163235264" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover transition-colors">
