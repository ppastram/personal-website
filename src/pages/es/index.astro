---
import BaseLayout from '../../layouts/BaseLayout.astro';

const locale = 'es' as const;

const questions = [
  '¿Cómo las estructuras de incentivos entre sectores determinan qué tecnología se adopta — y qué se ignora?',
  '¿Cómo se ve la gobernanza responsable de IA cuando las instituciones que gobiernan están siendo transformadas por la misma IA?',
  '¿Por qué fracasan la mayoría de los productos de govtech y regtech — y qué se necesitaría para construir unos que no?',
  '¿Qué pasa cuando llevas conversaciones de tecnología a comunidades que normalmente son excluidas de ellas?',
  '¿Cuándo la infraestructura de cumplimiento se convierte en lo que impide que las organizaciones realmente cambien?',
  '¿Cómo sería construir software que tome en serio la resistencia institucional?',
];
---

<BaseLayout title="Inicio" lang={locale}>
  <div class="typewriter-container">
    <p class="typewriter-text font-heading text-heading text-2xl leading-snug" id="typewriter" aria-live="polite"></p>
  </div>

  <script is:inline define:vars={{ questions }}>
    (function () {
      var el = document.getElementById('typewriter');
      if (!el) return;

      var CHAR_DELAY = 35;
      var PAUSE_AFTER = 1800;
      var ERASE_DELAY = 20;
      var PAUSE_BEFORE_NEXT = 400;
      var idx = 0;

      function type(text, cb) {
        var i = 0;
        (function next() {
          if (i <= text.length) {
            el.textContent = text.slice(0, i++);
            setTimeout(next, CHAR_DELAY);
          } else cb();
        })();
      }

      function erase(cb) {
        var text = el.textContent || '';
        var i = text.length;
        (function next() {
          if (i >= 0) {
            el.textContent = text.slice(0, i--);
            setTimeout(next, ERASE_DELAY);
          } else cb();
        })();
      }

      (function run() {
        type(questions[idx], function () {
          idx = (idx + 1) % questions.length;
          setTimeout(function () {
            erase(function () {
              setTimeout(run, PAUSE_BEFORE_NEXT);
            });
          }, PAUSE_AFTER);
        });
      })();
    })();
  </script>
</BaseLayout>
