---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readingList, categories, categoryLabels } from '../../data/reading';

const locale = 'es' as const;
---

<BaseLayout title="Lecturas" lang={locale} description="Libros, ensayos y pensadores que han moldeado cómo Pablo piensa sobre producto, instituciones y tecnología.">
  <article class="prose">
    <h1>Lecturas</h1>
    <p class="text-muted">
      Libros y ensayos que genuinamente cambiaron cómo pienso. No es una lista de "los 10 mejores" — solo los que se quedaron.
    </p>

    {categories.map((cat) => {
      const entries = readingList.filter((e) => e.category === cat);
      if (entries.length === 0) return null;
      return (
        <>
          <h2>{categoryLabels[cat].es}</h2>
          <ul>
            {entries.map((entry) => (
              <li>
                <strong>
                  {entry.url ? (
                    <a href={entry.url} target="_blank" rel="noopener noreferrer">{entry.title}</a>
                  ) : (
                    entry.title
                  )}
                </strong>
                {' '}<span class="text-muted">— {entry.author}{entry.year ? ` (${entry.year})` : ''}</span>
                {entry.note && (
                  <br /><span class="text-sm text-muted">{entry.note}</span>
                )}
              </li>
            ))}
          </ul>
        </>
      );
    })}
  </article>
</BaseLayout>
