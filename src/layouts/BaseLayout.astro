---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, type Locale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  ogImage?: string;
}

const { title, description = 'Builder at the intersection of computer science, anthropology, and how technology meets institutions.', ogImage } = Astro.props;
const ogImageUrl = new URL(ogImage || '/open-graph/site.png', Astro.site).href;
const locale = Astro.props.lang || getLocaleFromUrl(Astro.url);
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Pablo Pastrana Vega</title>

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title="Pablo Pastrana Vega" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} — Pablo Pastrana Vega`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Pablo Pastrana Vega`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <slot name="head" />

    <!-- Theme: prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-surface text-body font-body antialiased min-h-screen flex flex-col">
    <Header locale={locale} />
    <main class="flex-1 w-full max-w-3xl mx-auto px-6 py-12">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
